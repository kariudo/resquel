{
  "name": "@kariudo/resquel",
  "version": "1.0.1",
  "description": "Easily convert a SQL database into a REST API using Express.js.",
  "packageManager": "yarn@4.13.0",
  "main": "./lib/resquel.js",
  "types": "./lib/resquel.d.ts",
  "scripts": {
    "clean": "rm -rf ./lib",
    "clean:build": "yarn clean; yarn build",
    "build": "tsc -p tsconfig-build.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:mysql": "vitest run test/mysql.spec.ts",
    "test:mssql": "vitest run test/mssql.spec.ts",
    "test:postgresql": "vitest run test/postgresql.spec.ts",
    "prepare": "yarn clean:build"
  },
  "author": {
    "name": "Hunter Horsman",
    "email": "kariudo@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kariudo/resquel.git"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "basic-auth-connect": "^1.1.0",
    "body-parser": "^2.2.2",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "lodash": "^4.17.23",
    "method-override": "^3.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@faker-js/faker": "^10.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/body-parser": "^1.19.6",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/faker": "^6.6.11",
    "@types/knex": "^0.16.1",
    "@types/lodash": "^4.17.24",
    "@types/method-override": "^3.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^2.1.8",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
